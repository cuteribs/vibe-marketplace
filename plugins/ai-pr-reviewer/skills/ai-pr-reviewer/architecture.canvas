		{"id":"subagent-n","type":"text","text":"## Sub-agent N\n\n- Read batch-N-*.json\n- Read relevant guidelines\n- Review & post comments","x":1520,"y":740,"width":280,"height":160},
		{"id":"note-parallel","type":"text","text":"**All sub-agents run simultaneously in background**","x":1800,"y":1060,"width":200,"height":80},
